# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no repositório

# Chave secreta para assinar os tokens JWT — use uma string longa e aleatória
JWT_SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Hash bcrypt da senha do admin — gere com: python scripts/gerar_hash_senha.py
ADMIN_PASSWORD_HASH=$2b$12$SUBSTITUA_PELO_HASH_GERADO

# Origens permitidas para CORS (separadas por vírgula)
# Coloque a URL da interface da professora aqui
CORS_ORIGINS=http://localhost:5050,http://localhost:3000

# Ambiente (development ou production)
FLASK_ENV=production

# Porta da API
PORT=8000
